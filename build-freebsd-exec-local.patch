+#[derive(Clone, Debug, Default)]
+pub struct McpCatalogBuilder {
+    servers: BTreeMap<String, ResolvedMcpServer>,
+    disabled_server_names: BTreeSet<String>,
+}
+
+impl McpCatalogBuilder {
+    pub fn register(&mut self, registration: McpServerRegistration) {
+        let mut config = registration.config;
+        if self.disabled_server_names.contains(&registration.name) {
+            config.enabled = false;
+        }
+        self.servers.insert(
+            registration.name,
+            ResolvedMcpServer {
+                source: registration.source,
+                config,
+            },
+        );
+    }
+
+    pub fn disable(&mut self, name: String) {
+        self.disabled_server_names.insert(name.clone());
+        if let Some(server) = self.servers.get_mut(&name) {
+            server.config.enabled = false;
+        }
+    }
+
+    pub fn remove_compatibility(&mut self, name: String, _id: impl Into<String>) {
+        self.servers.remove(&name);
+    }
+
+    pub fn remove_extension(
+        &mut self,
+        name: String,
+        _id: impl Into<String>,
+        _contribution_order: usize,
+    ) {
+        self.servers.remove(&name);
+    }
+
+    pub fn build(self) -> ResolvedMcpCatalog {
+        ResolvedMcpCatalog {
+            servers: self.servers,
+            disabled_server_names: self.disabled_server_names,
+            conflicts: Vec::new(),
+        }
+    }
+}
