+    path.strip_prefix("plugin://")
+        .filter(|value| !value.is_empty())
+}
+
+pub fn extract_tool_mentions(text: &str) -> ToolMentions<'_> {
+    extract_tool_mentions_with_sigil(text, '$')
+}
+
+pub fn extract_tool_mentions_with_sigil(text: &str, sigil: char) -> ToolMentions<'_> {
+    let mut names = HashSet::new();
+    let paths = HashSet::new();
+    let mut plain_names = HashSet::new();
+    let bytes = text.as_bytes();
+    let mut index = 0;
+    while index < bytes.len() {
+        if bytes[index] != sigil as u8 {
+            index += 1;
+            continue;
+        }
+        let start = index + 1;
+        let mut end = start;
+        while let Some(byte) = bytes.get(end)
+            && (byte.is_ascii_alphanumeric() || matches!(*byte, b'_' | b'-' | b'.'))
+        {
+            end += 1;
+        }
+        if end > start {
+            let name = &text[start..end];
+            names.insert(name);
+            plain_names.insert(name);
+        }
+        index = end.max(index + 1);
+    }
+
+    ToolMentions {
+        names,
+        paths,
+        plain_names,
+    }
+}
