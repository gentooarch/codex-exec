+        Self::new_with_restriction_product(codex_home, false, Some(Product::Codex))
+    }
+
+    pub fn new_with_restriction_product(
+        codex_home: AbsolutePathBuf,
+        _bundled_skills_enabled: bool,
+        _restriction_product: Option<Product>,
+    ) -> Self {
+        Self {
+            _codex_home: codex_home,
+            extra_roots: RwLock::new(Vec::new()),
+        }
+    }
+
+    pub fn set_extra_roots(&self, extra_roots: Vec<AbsolutePathBuf>) {
+        let mut roots = self
+            .extra_roots
+            .write()
+            .unwrap_or_else(std::sync::PoisonError::into_inner);
+        *roots = extra_roots;
+    }
+
+    pub async fn snapshot_for_config(
+        &self,
+        _input: &SkillsLoadInput,
+        _fs: Option<Arc<dyn ExecutorFileSystem>>,
+    ) -> HostSkillsSnapshot {
+        HostSkillsSnapshot::new(Arc::new(SkillLoadOutcome::default()))
+    }
