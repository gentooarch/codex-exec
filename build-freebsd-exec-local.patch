--- a/app-server/src/chatgpt_apps.rs	1970-01-01 01:00:00.000000000 +0100
+++ b/app-server/src/chatgpt_apps.rs	2026-07-01 12:51:15.000000000 +0200
@@ -0,0 +1,131 @@
+#[cfg(feature = "chatgpt-apps")]
+pub(crate) use codex_chatgpt::connectors;
+#[cfg(feature = "chatgpt-apps")]
+pub(crate) use codex_chatgpt::workspace_settings;
+
+#[cfg(not(feature = "chatgpt-apps"))]
+pub(crate) mod workspace_settings {
+    use codex_core::config::Config;
+    use codex_login::CodexAuth;
+
+    #[derive(Debug, Default)]
+    pub(crate) struct WorkspaceSettingsCache;
+
+    pub(crate) async fn codex_plugins_enabled_for_workspace(
+        _config: &Config,
+        _auth: Option<&CodexAuth>,
+        _cache: Option<&WorkspaceSettingsCache>,
+    ) -> anyhow::Result<bool> {
+        Ok(false)
+    }
+}
+
+#[cfg(not(feature = "chatgpt-apps"))]
+pub(crate) mod connectors {
+    use std::collections::HashMap;
+    use std::collections::HashSet;
+    use std::sync::Arc;
+
+    use codex_app_server_protocol::AppInfo;
+    use codex_core::McpManager;
+    use codex_core::config::Config;
+    use codex_core::connectors::AccessibleConnectorsStatus;
+    use codex_exec_server::EnvironmentManager;
+    use codex_plugin::AppConnectorId;
+
+    pub(crate) async fn list_cached_accessible_connectors_from_mcp_tools(
+        _config: &Config,
+    ) -> Option<Vec<AppInfo>> {
+        Some(Vec::new())
+    }
+
+    pub(crate) async fn list_cached_all_connectors(
+        _config: &Config,
+        _plugin_apps: &[AppConnectorId],
+    ) -> Option<Vec<AppInfo>> {
+        Some(Vec::new())
+    }
+
+    pub(crate) async fn list_accessible_connectors_from_mcp_tools_with_mcp_manager(
+        _config: &Config,
+        _force_refetch: bool,
+        _environment_manager: Arc<EnvironmentManager>,
+        _mcp_manager: Arc<McpManager>,
+    ) -> anyhow::Result<AccessibleConnectorsStatus> {
+        Ok(AccessibleConnectorsStatus {
+            connectors: Vec::new(),
+            codex_apps_ready: true,
+        })
+    }
+
+    pub(crate) async fn list_all_connectors_with_options(
+        _config: &Config,
+        _force_refetch: bool,
+        _plugin_apps: &[AppConnectorId],
+    ) -> anyhow::Result<Vec<AppInfo>> {
+        Ok(Vec::new())
+    }
+
+    pub(crate) fn with_app_enabled_state(
+        connectors: Vec<AppInfo>,
+        _config: &Config,
+    ) -> Vec<AppInfo> {
+        connectors
+    }
+
+    pub(crate) fn connectors_for_plugin_apps(
+        connectors: Vec<AppInfo>,
+        plugin_apps: &[AppConnectorId],
+    ) -> Vec<AppInfo> {
+        if plugin_apps.is_empty() {
+            return Vec::new();
+        }
+        connectors
+            .into_iter()
+            .filter(|connector| {
+                plugin_apps
+                    .iter()
+                    .any(|plugin_app| plugin_app.0 == connector.id)
+            })
+            .collect()
+    }
+
+    pub(crate) fn merge_connectors_with_accessible(
+        all_connectors: Vec<AppInfo>,
+        accessible_connectors: Vec<AppInfo>,
+        all_connectors_loaded: bool,
+    ) -> Vec<AppInfo> {
+        let accessible_connectors = if all_connectors_loaded {
+            let connector_ids = all_connectors
+                .iter()
+                .map(|connector| connector.id.as_str())
+                .collect::<HashSet<_>>();
+            accessible_connectors
+                .into_iter()
+                .filter(|connector| connector_ids.contains(connector.id.as_str()))
+                .collect()
+        } else {
+            accessible_connectors
+        };
+
+        let mut merged = all_connectors
+            .into_iter()
+            .map(|mut connector| {
+                connector.is_accessible = false;
+                (connector.id.clone(), connector)
+            })
+            .collect::<HashMap<_, _>>();
+
+        for mut connector in accessible_connectors {
+            connector.is_accessible = true;
+            merged
+                .entry(connector.id.clone())
+                .and_modify(|existing| existing.is_accessible = true)
+                .or_insert(connector);
+        }
+
+        let mut merged = merged.into_values().collect::<Vec<_>>();
+        merged.sort_by(|left, right| left.name.cmp(&right.name).then(left.id.cmp(&right.id)));
+        merged
+    }
+}
