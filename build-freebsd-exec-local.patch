-impl RunReporter {
-    fn wait_for_complete(&self) -> FileSearchSnapshot {
-        let (cv, mutex) = &self.completed;
-        #[allow(clippy::unwrap_used)]
-        let mut completed = mutex.lock().unwrap();
-        while !*completed {
-            #[allow(clippy::unwrap_used)]
