+        Self {
+            _codex_home: codex_home,
+            auth_mode: RwLock::new(auth_mode),
+        }
+    }
+
+    pub fn set_auth_mode(&self, auth_mode: Option<AuthMode>) -> bool {
+        let mut stored = self
+            .auth_mode
+            .write()
+            .unwrap_or_else(std::sync::PoisonError::into_inner);
+        if *stored == auth_mode {
+            return false;
+        }
+        *stored = auth_mode;
+        true
+    }
+
+    pub fn auth_mode(&self) -> Option<AuthMode> {
+        *self
+            .auth_mode
+            .read()
+            .unwrap_or_else(std::sync::PoisonError::into_inner)
+    }
