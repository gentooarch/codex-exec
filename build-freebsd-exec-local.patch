+pub async fn compute_auth_statuses<'a, I>(
+    servers: I,
+    _store_mode: OAuthCredentialsStoreMode,
+    _keyring_backend_kind: AuthKeyringBackendKind,
+    _auth: Option<&CodexAuth>,
+) -> HashMap<String, McpAuthStatusEntry>
+where
+    I: IntoIterator<Item = (&'a String, &'a EffectiveMcpServer)>,
+{
+    servers
+        .into_iter()
+        .map(|(name, server)| {
+            let config = server.configured_config().cloned();
+            let auth_status = match config.as_ref().map(|config| &config.transport) {
+                Some(McpServerTransportConfig::StreamableHttp {
+                    bearer_token_env_var,
+                    http_headers,
+                    ..
+                }) if bearer_token_env_var.is_some()
+                    || http_headers.as_ref().is_some_and(|headers| {
+                        headers
+                            .keys()
+                            .any(|key| key.eq_ignore_ascii_case("authorization"))
+                    }) =>
+                {
+                    McpAuthStatus::BearerToken
+                }
+                _ => McpAuthStatus::Unsupported,
+            };
+            (
+                name.clone(),
+                McpAuthStatusEntry {
+                    config,
+                    auth_status,
+                },
+            )
+        })
+        .collect()
+}
