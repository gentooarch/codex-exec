+
+fn ring_terminal_bell() {
+    let mut stderr = std::io::stderr();
+    if std::io::IsTerminal::is_terminal(&stderr) {
+        let _ = std::io::Write::write_all(&mut stderr, b"\x07");
+        let _ = std::io::Write::flush(&mut stderr);
+    }
+}
+
+fn cache_hit_rate_line(input_tokens: i64, cached_input_tokens: i64) -> String {
+    let input = input_tokens.max(0);
+    let cached = cached_input_tokens.max(0).min(input);
+    if input == 0 {
+        return "cache hit: n/a (0 input tokens)".to_string();
+    }
+
+    let rate = cached as f64 * 100.0 / input as f64;
+    format!(
+        "cache hit: {rate:.1}% ({}/{})",
+        codex_protocol::num_format::format_with_separators(cached),
+        codex_protocol::num_format::format_with_separators(input)
+    )
+}
