+#[derive(Clone, Copy, Debug, PartialEq, Eq)]
+pub enum ToolMentionKind {
+    App,
+    Mcp,
+    Plugin,
+    Skill,
+    Other,
+}
+
+pub fn tool_kind_for_path(path: &str) -> ToolMentionKind {
+    if path.starts_with("app://") {
+        ToolMentionKind::App
+    } else if path.starts_with("mcp://") {
+        ToolMentionKind::Mcp
+    } else if path.starts_with("plugin://") {
+        ToolMentionKind::Plugin
+    } else if path.starts_with("skill://") || path.ends_with("/SKILL.md") || path == "SKILL.md" {
+        ToolMentionKind::Skill
+    } else {
+        ToolMentionKind::Other
+    }
+}
