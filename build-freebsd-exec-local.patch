+use std::collections::BTreeMap;
+
+#[derive(Debug, Clone, Serialize, Deserialize, Default, PartialEq, Eq)]
+#[serde(default)]
+pub struct MitmHookConfig {
+    pub host: String,
+    #[serde(rename = "match", default)]
+    pub matcher: MitmHookMatchConfig,
+    #[serde(default)]
+    pub actions: MitmHookActionsConfig,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize, Default, PartialEq, Eq)]
+#[serde(default)]
+pub struct MitmHookMatchConfig {
+    pub methods: Vec<String>,
+    pub path_prefixes: Vec<String>,
+    pub query: BTreeMap<String, Vec<String>>,
+    pub headers: BTreeMap<String, Vec<String>>,
+    pub body: Option<MitmHookBodyConfig>,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize, Default, PartialEq, Eq)]
+#[serde(default)]
+pub struct MitmHookActionsConfig {
+    pub strip_request_headers: Vec<String>,
+    pub inject_request_headers: Vec<InjectedHeaderConfig>,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize, Default, PartialEq, Eq)]
+#[serde(default)]
+pub struct InjectedHeaderConfig {
+    pub name: String,
+    pub secret_env_var: Option<String>,
+    pub secret_file: Option<String>,
+    pub prefix: Option<String>,
+}
+
+#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq)]
+#[serde(transparent)]
+pub struct MitmHookBodyConfig(pub serde_json::Value);
+
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub struct MitmHook;
+
+pub type MitmHooksByHost = BTreeMap<String, Vec<MitmHook>>;
+
+#[derive(Debug, Clone, PartialEq, Eq)]
+pub enum HookEvaluation {
+    NoHooksForHost,
+    Matched,
+    HookedHostNoMatch,
+}
+
+pub(crate) fn validate_mitm_hook_config(config: &NetworkProxyConfig) -> anyhow::Result<()> {
+    if config.network.mitm_hooks.is_empty() {
+        Ok(())
+    } else {
+        anyhow::bail!("network.mitm_hooks is disabled in FreeBSD exec builds")
+    }
+}
+
+pub(crate) fn compile_mitm_hooks(config: &NetworkProxyConfig) -> anyhow::Result<MitmHooksByHost> {
+    validate_mitm_hook_config(config)?;
+    Ok(MitmHooksByHost::new())
+}
+
+pub(crate) fn evaluate_mitm_hooks<T>(
+    _hooks_by_host: &MitmHooksByHost,
+    _host: &str,
