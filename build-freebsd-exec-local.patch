@@ -0,0 +1,388 @@
+use crate::config;
+use crate::network_policy::NetworkPolicyDecider;
+use crate::runtime::BlockedRequestObserver;
+use crate::runtime::ConfigState;
+use crate::state::NetworkProxyState;
+use anyhow::Result;
+use codex_utils_absolute_path::AbsolutePathBuf;
+use std::collections::HashMap;
+use std::net::SocketAddr;
+use std::sync::Arc;
+use std::sync::RwLock;
+use tracing::warn;
+
+const DISABLED_MESSAGE: &str = "managed network proxy is disabled in FreeBSD exec builds";
+
+#[derive(Debug, Clone, Default)]
+pub struct Args {}
+
+#[derive(Clone)]
+pub struct NetworkProxyBuilder {
+    state: Option<Arc<NetworkProxyState>>,
+    http_addr: Option<SocketAddr>,
+    socks_addr: Option<SocketAddr>,
+    managed_by_codex: bool,
+    policy_decider: Option<Arc<dyn NetworkPolicyDecider>>,
+    blocked_request_observer: Option<Arc<dyn BlockedRequestObserver>>,
+}
+
+impl Default for NetworkProxyBuilder {
+    fn default() -> Self {
+        Self {
+            state: None,
+            http_addr: None,
+            socks_addr: None,
+            managed_by_codex: true,
+            policy_decider: None,
+            blocked_request_observer: None,
+        }
+    }
+}
+
+impl NetworkProxyBuilder {
+    pub fn state(mut self, state: Arc<NetworkProxyState>) -> Self {
+        self.state = Some(state);
+        self
+    }
+
+    pub fn http_addr(mut self, addr: SocketAddr) -> Self {
+        self.http_addr = Some(addr);
+        self
+    }
+
+    pub fn socks_addr(mut self, addr: SocketAddr) -> Self {
+        self.socks_addr = Some(addr);
+        self
+    }
+
+    pub fn managed_by_codex(mut self, managed_by_codex: bool) -> Self {
+        self.managed_by_codex = managed_by_codex;
+        self
+    }
+
+    pub fn policy_decider<D>(mut self, decider: D) -> Self
+    where
+        D: NetworkPolicyDecider,
+    {
+        self.policy_decider = Some(Arc::new(decider));
+        self
+    }
+
+    pub fn policy_decider_arc(mut self, decider: Arc<dyn NetworkPolicyDecider>) -> Self {
+        self.policy_decider = Some(decider);
+        self
+    }
+
+    pub fn blocked_request_observer<O>(mut self, observer: O) -> Self
+    where
+        O: BlockedRequestObserver,
+    {
+        self.blocked_request_observer = Some(Arc::new(observer));
+        self
+    }
+
+    pub fn blocked_request_observer_arc(
+        mut self,
+        observer: Arc<dyn BlockedRequestObserver>,
+    ) -> Self {
+        self.blocked_request_observer = Some(observer);
+        self
+    }
+
+    pub async fn build(self) -> Result<NetworkProxy> {
+        let state = self.state.ok_or_else(|| {
+            anyhow::anyhow!(
+                "NetworkProxyBuilder requires a state; supply one via builder.state(...)"
+            )
+        })?;
+        state
+            .set_blocked_request_observer(self.blocked_request_observer.clone())
+            .await;
+        let current_cfg = state.current_cfg().await?;
+        let runtime_settings = RuntimeSettings::from_config_and_overrides(
+            &current_cfg,
+            self.http_addr,
+            self.socks_addr,
+            self.managed_by_codex,
+        )?;
+        Ok(NetworkProxy {
+            state,
+            runtime_settings: Arc::new(RwLock::new(runtime_settings)),
+        })
+    }
+}
+
+#[derive(Debug, Clone, PartialEq, Eq)]
+struct RuntimeSettings {
+    http_addr: SocketAddr,
+    socks_addr: SocketAddr,
+    allow_local_binding: bool,
+    allow_unix_sockets: Arc<[String]>,
+    dangerously_allow_all_unix_sockets: bool,
+}
+
+impl RuntimeSettings {
+    fn from_config_and_overrides(
+        cfg: &config::NetworkProxyConfig,
+        http_addr: Option<SocketAddr>,
+        socks_addr: Option<SocketAddr>,
+        managed_by_codex: bool,
+    ) -> Result<Self> {
+        let runtime = config::resolve_runtime(cfg)?;
+        let (http_addr, socks_addr) = if managed_by_codex {
+            (runtime.http_addr, runtime.socks_addr)
+        } else {
+            let requested_http_addr = http_addr.unwrap_or(runtime.http_addr);
+            let requested_socks_addr = socks_addr.unwrap_or(runtime.socks_addr);
+            config::clamp_bind_addrs(requested_http_addr, requested_socks_addr, &cfg.network)
+        };
+        Ok(Self {
+            http_addr,
+            socks_addr,
+            allow_local_binding: cfg.network.allow_local_binding,
+            allow_unix_sockets: cfg.network.allow_unix_sockets().into(),
+            dangerously_allow_all_unix_sockets: cfg.network.dangerously_allow_all_unix_sockets,
+        })
+    }
+}
+
+#[derive(Clone)]
+pub struct NetworkProxy {
+    state: Arc<NetworkProxyState>,
+    runtime_settings: Arc<RwLock<RuntimeSettings>>,
+}
+
+impl std::fmt::Debug for NetworkProxy {
+    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+        let runtime_settings = self.runtime_settings();
+        f.debug_struct("NetworkProxy")
+            .field("http_addr", &runtime_settings.http_addr)
+            .field("socks_addr", &runtime_settings.socks_addr)
+            .finish_non_exhaustive()
+    }
+}
+
+impl PartialEq for NetworkProxy {
+    fn eq(&self, other: &Self) -> bool {
+        self.runtime_settings() == other.runtime_settings()
+    }
+}
+
+impl Eq for NetworkProxy {}
+
